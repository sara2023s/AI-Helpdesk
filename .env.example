# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (server-side — used in API routes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (frontend — exposed via Vite build)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Slack (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Usage limits (tokens per window)
FIVE_HOUR_LIMIT=50000
SEVEN_DAY_LIMIT=500000

# Auto-progress tickets through agent pipeline (true/false)
AUTO_PROGRESS=true
